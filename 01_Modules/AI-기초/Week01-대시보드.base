filters:
  and:
    - file.inFolder("01_Modules/AI-기초")

properties:
  file.name:
    displayName: 강의
  day:
    displayName: 일차
  title:
    displayName: 제목
  status:
    displayName: 상태

views:
  - type: table
    name: "Week01 - AI Literacy"
    order:
      - day
      - file.name
      - title
      - status
