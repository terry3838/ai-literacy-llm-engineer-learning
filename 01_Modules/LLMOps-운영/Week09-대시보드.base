filters:
  and:
    - file.inFolder("01_Modules/LLMOps-운영")

properties:
  file.name:
    displayName: 강의
  day:
    displayName: 일차
  title:
    displayName: 제목
  topic:
    displayName: 주제
  status:
    displayName: 상태

views:
  - type: table
    name: "Week09 - LLMOps/배포"
    order:
      - day
      - file.name
      - title
      - topic
      - status
