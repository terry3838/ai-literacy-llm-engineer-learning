filters:
  and:
    - file.inFolder("01_Modules/서비스-기획")

properties:
  file.name:
    displayName: 강의
  title:
    displayName: 제목
  topic:
    displayName: 주제
  status:
    displayName: 상태

views:
  - type: table
    name: "Week07 - AI 서비스 기획"
    order:
      - file.name
      - title
      - topic
      - status
