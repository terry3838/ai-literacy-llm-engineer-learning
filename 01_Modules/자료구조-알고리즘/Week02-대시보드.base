filters:
  and:
    - file.inFolder("01_Modules/자료구조-알고리즘")

properties:
  file.name:
    displayName: 강의
  day:
    displayName: 일차
  title:
    displayName: 제목
  status:
    displayName: 상태

views:
  - type: table
    name: "Week02 - 자료구조/알고리즘"
    order:
      - day
      - file.name
      - title
      - status
