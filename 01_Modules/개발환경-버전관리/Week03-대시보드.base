filters:
  and:
    - file.inFolder("01_Modules/개발환경-버전관리")

properties:
  file.name:
    displayName: 강의
  day:
    displayName: 일차
  title:
    displayName: 제목
  status:
    displayName: 상태

views:
  - type: table
    name: "Week03 - 개발환경/Git/Docker"
    order:
      - day
      - file.name
      - title
      - status
