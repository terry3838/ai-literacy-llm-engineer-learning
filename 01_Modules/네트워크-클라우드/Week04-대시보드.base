filters:
  and:
    - file.inFolder("01_Modules/네트워크-클라우드")

properties:
  file.name:
    displayName: 강의
  day:
    displayName: 일차
  title:
    displayName: 제목
  topic:
    displayName: 주제
  status:
    displayName: 상태

views:
  - type: table
    name: "Week04 - 네트워크/클라우드"
    order:
      - day
      - file.name
      - title
      - topic
      - status
