filters:
  and:
    - file.inFolder("04_Exercises")

formulas:
  완료여부: 'if(status == "완료", "✅", "⏳")'

properties:
  file.name:
    displayName: 실습
  week:
    displayName: 주차
  day:
    displayName: 일차
  title:
    displayName: 제목
  status:
    displayName: 상태
  formula.완료여부:
    displayName: ""

views:
  - type: table
    name: "전체 실습"
    order:
      - formula.완료여부
      - week
      - day
      - file.name
      - title
      - status
    groupBy:
      property: week
      direction: ASC
    summaries:
      formula.완료여부: Filled

  - type: table
    name: "미완료 실습"
    filters:
      not:
        - 'status == "완료"'
    order:
      - week
      - day
      - file.name
      - status
